<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="50dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="0dp"
    android:paddingEnd="6dp">

    <!-- Category colour strip (left) -->
    <View
        android:id="@+id/widget_item_color_strip"
        android:layout_width="3dp"
        android:layout_height="30dp"
        android:background="#FFEF4444"
        android:layout_marginEnd="10dp" />

    <!-- Title + subtitle column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Title row (pin emoji injected via code if pinned) -->
        <TextView
            android:id="@+id/widget_item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voice Memo"
            android:textSize="12sp"
            android:textColor="#FFFFFFFF"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Duration · relative time -->
        <TextView
            android:id="@+id/widget_item_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0:30 · Just now"
            android:textSize="9sp"
            android:textColor="#65FFFFFF"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Play / listen button -->
    <ImageView
        android:id="@+id/widget_item_play"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_play"
        android:background="@drawable/widget_play_btn_bg"
        android:scaleType="center"
        android:padding="7dp"
        android:contentDescription="Play" />

</LinearLayout>
