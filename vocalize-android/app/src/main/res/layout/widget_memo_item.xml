<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">

    <!-- Category colour dot -->
    <View
        android:id="@+id/widget_item_color_dot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="#FFEF4444"
        android:layout_marginEnd="10dp" />

    <!-- Title and duration -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/widget_item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voice Memo"
            android:textSize="13sp"
            android:textColor="#FFFFFFFF"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_item_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0:30 · Just now"
            android:textSize="10sp"
            android:textColor="#80FFFFFF"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Play button -->
    <ImageView
        android:id="@+id/widget_item_play"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_play"
        android:scaleType="center"
        android:background="#33FFFFFF"
        android:padding="6dp"
        android:contentDescription="@string/memo_play" />

</LinearLayout>
